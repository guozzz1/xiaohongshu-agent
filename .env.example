XHS_USERNAME=
XHS_PASSWORD=
# Cookie 必须含 web_session。获取方式：F12 → Network → 刷新页 → 任选请求 → Headers → 复制 Cookie 整行
# 支持格式: {"cookie":"a=1; web_session=xxx; ..."} 或直接 "a=1; web_session=xxx; ..."
XHS_COOKIES_JSON=

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=

# 可选：自定义每天采集条数
DAILY_TARGET=20
MIN_COMMENTS=200
STRICT_COMMENT_FILTER=1
MAX_RETRY=3
SEARCH_WAIT_MS=2600
BROWSER_CHANNEL=msedge
CAPTCHA_WAIT_SECONDS=180
HEADLESS=0
MIN_REQUEST_INTERVAL_SECONDS=2.2
MAX_REQUEST_INTERVAL_SECONDS=5.8
RATE_LIMIT_COOLDOWN_SECONDS=90
MAX_RATE_LIMIT_RETRY=3
FIXED_KEYWORDS=
LOGIN_WAIT_SECONDS=180
# 0=无人值守仅cookie登录 1=允许扫码等待
REQUIRE_INTERACTIVE_LOGIN=0
# 1=为小红书API请求注入x-s/x-t/x-s-common签名（需xhshow库）
USE_XHS_SIGN=1
GOTO_TIMEOUT_MS=90000
SEARCH_GOTO_RETRY=3
FALLBACK_NOTE_URLS=

# 创作者发布页（上传图文为 target=image，勿用裸路径否则会进 target=video）
XHS_PUBLISH_PAGE_URL=https://creator.xiaohongshu.com/publish/publish?from=menu&target=image
# 图文发布须先选图才会出现标题框：自动上传占位图（默认 2 张，可改 1～9）
# SKIP_PUBLISH_PLACEHOLDER_UPLOAD=1
# PUBLISH_PLACEHOLDER_IMAGE_COUNT=2
# PUBLISH_PLACEHOLDER_IMAGE_PATH=D:\path\to\your.jpg
# 发布页实际上传图片（逗号分隔本地路径，优先于从 note.image_urls 解析）
# PUBLISH_IMAGE_PATHS=D:\a.jpg,D:\b.jpg

# 持久化浏览器上下文目录（建议开启，复用登录态，减少creator页异常）
PERSISTENT_USER_DATA_DIR=.xhs_profile

# 1=降低自动化特征（默认开启）。若仍提示「版本太低」，用手动 Edge 开调试端口后走 CDP
STEALTH_BROWSER=1
# 先启动 Edge：msedge --remote-debugging-port=9222 --user-data-dir=你的目录
# 再设 CONNECT_CDP_URL=http://127.0.0.1:9222（脚本将连接已打开窗口，不再注入 cookie）
CONNECT_CDP_URL=

# 大模型API配置（用于智能二创）
LLM_API_TYPE=openai  # 可选: openai, azure, qwen, deepseek, moonshot
LLM_API_KEY=你的API密钥
LLM_API_BASE_URL=https://api.openai.com/v1  # 根据API类型调整
LLM_MODEL=gpt-3.5-turbo  # 根据API类型选择合适的模型
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
